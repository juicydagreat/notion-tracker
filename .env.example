HELIUS_API_KEY=your_helius_api_key_here
HELIUS_RPC_URL=https://mainnet.helius-rpc.com/?api-key=your_helius_api_key_here

# Free public RPC — used for getSignaturesForAddress and getTransaction
# so Helius credits are only spent on getBlock (when a unique fee is found).
# Alternatives:
#   https://rpc.ankr.com/solana         (Ankr — often faster)
#   https://solana-mainnet.g.alchemy.com/v2/demo  (Alchemy demo key)
FREE_RPC_URL=https://api.mainnet-beta.solana.com

WALLETS_FILE=wallets.json
DB_PATH=discovery.db

# Safety limit: daemon stops when this many Helius credits are used per run.
# With dual-RPC mode, only getBlock calls consume credits (~10 per block scan).
# 50 credits ≈ 5 block scans — very conservative for the free plan.
MAX_CREDITS_PER_RUN=50
